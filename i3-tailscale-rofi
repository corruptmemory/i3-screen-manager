#!/usr/bin/env bash
#
# i3-tailscale-rofi — toggle Tailscale on/off and switch Open Brain MCP URL
#
# When Tailscale comes up, the Open Brain MCP URL in ~/.claude.json is switched
# from the home-LAN hostname (only reachable on VLAN 30) to the Tailscale IP
# (reachable from anywhere on the tailnet). Reversed when Tailscale goes down.
#
# Prerequisite on node-0: Open Brain must listen on 0.0.0.0:8000 (not
# 127.0.0.1:8000) so the Tailscale IP can reach it. Edit config.toml:
#   [mcp]
#   listen = "0.0.0.0:8000"
# then restart the open-brain service.

set -euo pipefail

# --- Config ---
BRAIN_KEY=$(jq -r '.mcpServers["open-brain"].headers["x-brain-key"]' ~/.claude.json 2>/dev/null || echo "")
BRAIN_URL_LAN="http://open-brain/"
BRAIN_URL_TS="http://100.118.98.4:8000/"   # node-0 Tailscale IP

# --- Helpers ---

ts_backend_state() {
    # Returns the BackendState string from tailscale status --json:
    #   Running     → connected to tailnet
    #   Stopped     → tailscale down (daemon up, not connected)
    #   NeedsLogin  → not authenticated
    #   NoState     → daemon just started, never connected
    tailscale status --json 2>/dev/null \
        | python3 -c "import sys,json; print(json.load(sys.stdin).get('BackendState','NoState'))" \
        2>/dev/null || echo "NoState"
}

brain_url_current() {
    jq -r '.mcpServers["open-brain"].url' ~/.claude.json 2>/dev/null || echo ""
}

set_brain_url() {
    local url="$1"
    local tmp
    tmp=$(mktemp)
    jq --arg url "$url" '.mcpServers["open-brain"].url = $url' ~/.claude.json > "$tmp" \
        && mv "$tmp" ~/.claude.json
}

open_login_url() {
    # Ask tailscale for a fresh auth URL and open it in the browser.
    local output url
    output=$(timeout 10 tailscale login 2>&1 || true)
    url=$(echo "$output" | grep -oE 'https://login\.tailscale\.com/[^[:space:]]+' | head -1)
    if [[ -n "$url" ]]; then
        xdg-open "$url" &
        notify-send -t 6000 "Tailscale" "Login required — browser opened" 2>/dev/null || true
    else
        notify-send -t 6000 "Tailscale" "Login failed — network may be blocking Tailscale control plane" 2>/dev/null || true
    fi
}

ts_up() {
    local state output url

    state=$(ts_backend_state)

    if [[ "$state" == "NeedsLogin" ]]; then
        open_login_url
        return
    fi

    # Try to connect; tailscale up can also emit a login URL if auth expired mid-session
    output=$(timeout 10 tailscale up --accept-dns=false --hostname=nomad-artix 2>&1) && {
        set_brain_url "$BRAIN_URL_TS"
        notify-send -t 3000 "Tailscale" "Connected — Open Brain → Tailscale IP" 2>/dev/null || true
        return
    }

    url=$(echo "$output" | grep -oE 'https://login\.tailscale\.com/[^[:space:]]+' | head -1)
    if [[ -n "$url" ]]; then
        xdg-open "$url" &
        notify-send -t 6000 "Tailscale" "Login required — browser opened" 2>/dev/null || true
    else
        notify-send -t 5000 "Tailscale" "Error: $(echo "$output" | head -2 | tr '\n' ' ')" 2>/dev/null || true
    fi
}

ts_down() {
    tailscale down
    set_brain_url "$BRAIN_URL_LAN"
    notify-send -t 3000 "Tailscale" "Disconnected — Open Brain → LAN" 2>/dev/null || true
}

# --- Menu ---

state=$(ts_backend_state)
brain_url=$(brain_url_current)

case "$state" in
    Running)
        current_label="● Tailscale: On"
        toggle_label="  Turn Off"
        ;;
    NeedsLogin)
        current_label="● Tailscale: Needs Login"
        toggle_label="  Log In"
        ;;
    *)
        current_label="● Tailscale: Off"
        toggle_label="  Turn On"
        ;;
esac

brain_label="  Open Brain: $(basename "$brain_url" | sed 's|/||')"

choice=$(printf "%s\n%s\n%s" \
    "$current_label" \
    "$toggle_label" \
    "$brain_label" \
    | rofi -dmenu -i -p "Network" -theme-str 'window {width: 320px;}') || exit 0

case "$choice" in
    *"Turn On"*|*"Log In"*)  ts_up ;;
    *"Turn Off"*)             ts_down ;;
    *"Open Brain"*)
        # Manual URL toggle — useful if status drifted out of sync
        if [[ "$brain_url" == "$BRAIN_URL_LAN" ]]; then
            set_brain_url "$BRAIN_URL_TS"
            notify-send -t 2000 "Open Brain" "→ Tailscale IP" 2>/dev/null || true
        else
            set_brain_url "$BRAIN_URL_LAN"
            notify-send -t 2000 "Open Brain" "→ LAN" 2>/dev/null || true
        fi
        ;;
esac
