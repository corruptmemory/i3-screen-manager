#!/usr/bin/env bash
#
# i3-screen-manager — manage external displays on Hyprland/Wayland
#
# Usage:
#   i3-screen-manager <command>
#
# Commands:
#   extend-left     External monitor to the left of laptop
#   extend-right    External monitor to the right of laptop
#   extend-above    External monitor above laptop
#   extend-below    External monitor below laptop
#   clamshell       External monitor only, laptop screen off, lid-close safe
#   mirror          Mirror displays (external mirrors laptop)
#   disconnect      Revert to laptop screen only
#   scale [VALUE]   Set monitor scale (shows rofi picker if no value given)
#   status          Show current display state
#

set -euo pipefail

INTERNAL="eDP-1"
INTERNAL_SCALE=1.25
EXTERNAL_SCALE=1.0
PIDFILE="/tmp/i3-screen-manager-inhibit.pid"

# --- Detection ---

find_external() {
    hyprctl monitors -j 2>/dev/null | \
        jq -r --arg int "$INTERNAL" '.[] | select(.name != $int) | .name' | head -1
}

find_lid_state() {
    local f
    for f in /proc/acpi/button/lid/*/state; do
        [[ -f "$f" ]] && echo "$f" && return
    done
}

lid_is_open() {
    local lid_state
    lid_state=$(find_lid_state)
    if [[ -n "$lid_state" ]]; then
        grep -q "open" "$lid_state"
    else
        return 1  # Can't detect — assume closed (safe default)
    fi
}

inhibitor_is_active() {
    [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

# --- Monitor info helpers ---

# Logical width/height account for scale (what Hyprland uses for layout)
monitor_logical_width() {
    hyprctl monitors -j | jq --arg n "$1" \
        '.[] | select(.name==$n) | (.width / .scale) | floor'
}

monitor_logical_height() {
    hyprctl monitors -j | jq --arg n "$1" \
        '.[] | select(.name==$n) | (.height / .scale) | floor'
}

# Physical pixel dimensions of the preferred (first) mode
preferred_width() {
    hyprctl monitors -j | jq -r --arg n "$1" \
        '.[] | select(.name==$n) | .availableModes[0]' | grep -oP '^\d+'
}

preferred_height() {
    hyprctl monitors -j | jq -r --arg n "$1" \
        '.[] | select(.name==$n) | .availableModes[0]' | grep -oP 'x\K\d+'
}

# Mode string for hyprctl: "2560x1440@59.95" (no Hz suffix)
preferred_mode() {
    hyprctl monitors -j | jq -r --arg n "$1" \
        '.[] | select(.name==$n) | .availableModes[0]' | sed 's/Hz//'
}

# --- Inhibitor ---

start_inhibitor() {
    stop_inhibitor
    elogind-inhibit --what=handle-lid-switch \
        --who="i3-screen-manager" \
        --why="Clamshell mode — lid close safe" \
        --mode=block sleep infinity &
    echo $! > "$PIDFILE"
}

stop_inhibitor() {
    if [[ -f "$PIDFILE" ]]; then
        local pid
        pid=$(cat "$PIDFILE")
        kill "$pid" 2>/dev/null || true
        rm -f "$PIDFILE"
    fi
}

# --- Workspace management ---

move_workspaces_to() {
    local target="$1"
    hyprctl workspaces -j | jq -r '.[].id' | while read -r wsid; do
        hyprctl dispatch moveworkspacetomonitor "$wsid" "$target" 2>/dev/null || true
    done
}

move_workspaces_from() {
    local source="$1"
    local target="$2"
    hyprctl workspaces -j | jq -r --arg src "$source" \
        '.[] | select(.monitor == $src) | .id' | while read -r wsid; do
        hyprctl dispatch moveworkspacetomonitor "$wsid" "$target" 2>/dev/null || true
    done
}

ensure_workspace_on() {
    local target="$1"
    local count
    count=$(hyprctl workspaces -j | jq --arg mon "$target" \
        '[.[] | select(.monitor == $mon)] | length')
    if [[ "$count" -eq 0 ]]; then
        local next
        next=$(hyprctl workspaces -j | jq '[.[].id] | max + 1')
        hyprctl dispatch moveworkspacetomonitor "$next" "$target" 2>/dev/null || true
    fi
}

# --- Commands ---

cmd_extend() {
    local direction="$1"
    local ext
    ext=$(find_external)
    if [[ -z "$ext" ]]; then
        echo "No external display found." >&2
        exit 1
    fi

    stop_inhibitor

    local int_lw int_lh ext_pw ext_ph ext_mode
    int_lw=$(monitor_logical_width "$INTERNAL")
    int_lh=$(monitor_logical_height "$INTERNAL")
    ext_pw=$(preferred_width "$ext")
    ext_ph=$(preferred_height "$ext")
    ext_mode=$(preferred_mode "$ext")

    # Ensure internal is active at its canonical position
    hyprctl keyword monitor "$INTERNAL,preferred,0x0,$INTERNAL_SCALE"

    case "$direction" in
        right) hyprctl keyword monitor "$ext,$ext_mode,${int_lw}x0,$EXTERNAL_SCALE" ;;
        left)  hyprctl keyword monitor "$ext,$ext_mode,-${ext_pw}x0,$EXTERNAL_SCALE" ;;
        above) hyprctl keyword monitor "$ext,$ext_mode,0x-${ext_ph},$EXTERNAL_SCALE" ;;
        below) hyprctl keyword monitor "$ext,$ext_mode,0x${int_lh},$EXTERNAL_SCALE" ;;
    esac

    ensure_workspace_on "$ext"
    echo "Extended $direction: $INTERNAL + $ext ($ext_mode)"
}

cmd_clamshell() {
    local ext
    ext=$(find_external)
    if [[ -z "$ext" ]]; then
        echo "No external display found. Cannot enter clamshell mode." >&2
        exit 1
    fi

    # Move all workspaces off the internal before disabling it
    move_workspaces_to "$ext"
    sleep 0.3

    # External at origin, internal off
    hyprctl keyword monitor "$ext,preferred,0x0,$EXTERNAL_SCALE"
    sleep 0.3
    hyprctl keyword monitor "$INTERNAL,disable"

    # Prevent suspend on lid close
    start_inhibitor

    echo "Clamshell: $ext only — lid-close safe"
}

cmd_mirror() {
    local ext
    ext=$(find_external)
    if [[ -z "$ext" ]]; then
        echo "No external display found." >&2
        exit 1
    fi

    stop_inhibitor

    hyprctl keyword monitor "$INTERNAL,preferred,0x0,$INTERNAL_SCALE"
    hyprctl keyword monitor "$ext,preferred,0x0,$EXTERNAL_SCALE,mirror,$INTERNAL"

    echo "Mirror: $ext mirrors $INTERNAL"
}

cmd_disconnect() {
    if ! lid_is_open; then
        echo "Lid is closed. Open the lid first, then run disconnect again." >&2
        return 1
    fi

    stop_inhibitor

    local ext
    ext=$(find_external)

    # Re-enable internal first — no window where zero displays are active
    hyprctl keyword monitor "$INTERNAL,preferred,0x0,$INTERNAL_SCALE"
    sleep 0.3

    if [[ -n "$ext" ]]; then
        move_workspaces_from "$ext" "$INTERNAL"
        sleep 0.2
        hyprctl keyword monitor "$ext,disable"
        echo "Disconnected: $ext off, $INTERNAL restored"
    else
        echo "Internal display restored (no external was active)"
    fi
}

cmd_scale() {
    local scale="${1:-}"
    local target="${2:-$INTERNAL}"

    if [[ -z "$scale" ]]; then
        local current
        current=$(hyprctl monitors -j | jq -r --arg n "$target" \
            '.[] | select(.name==$n) | .scale')
        scale=$(printf "0.75\n1.00\n1.25\n1.50\n1.75\n2.00" \
            | rofi -dmenu -i -p "Scale for $target (current: ${current:-?})" \
                -theme-str 'window {width: 300px;}')
    fi

    if [[ -n "$scale" && "$scale" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        hyprctl keyword monitor "$target,preferred,auto,$scale"
        echo "Scale set to $scale on $target"
    else
        echo "Invalid scale value: $scale" >&2
        return 1
    fi
}

cmd_status() {
    local ext
    ext=$(find_external)

    echo "Internal: $INTERNAL"
    if [[ -n "$ext" ]]; then
        echo "External: $ext"
    else
        echo "External: none detected"
    fi

    echo ""
    echo "Active monitors:"
    hyprctl monitors -j | jq -r \
        '.[] | "  \(.name): \(.width)x\(.height)@\(.refreshRate | floor)Hz  pos=\(.x),\(.y)  scale=\(.scale)\(if .disabled then "  [disabled]" else "" end)"'

    echo ""
    if inhibitor_is_active; then
        echo "Clamshell inhibitor: active"
    else
        echo "Clamshell inhibitor: inactive"
    fi
}

# --- Main ---

usage() {
    sed -n '3,/^$/s/^# \?//p' "$0"
    exit 1
}

case "${1:-}" in
    extend-left)  cmd_extend left ;;
    extend-right) cmd_extend right ;;
    extend-above) cmd_extend above ;;
    extend-below) cmd_extend below ;;
    clamshell)    cmd_clamshell ;;
    mirror)       cmd_mirror ;;
    disconnect)   cmd_disconnect ;;
    scale)        cmd_scale "${2:-}" "${3:-}" ;;
    status)       cmd_status ;;
    *)            usage ;;
esac
