#!/bin/sh
# Hyprland session launcher — Artix/OpenRC, Intel Iris Xe + NVIDIA RTX 3050 Ti Mobile
# Symlink: ~/.config/hypr/hyprland.conf -> ~/projects/dotfiles/.config/hypr/hyprland-laptop.conf

# Locale — /etc/locale.conf isn't loaded automatically on OpenRC (no pam_systemd)
export LANG=en_US.UTF-8
export LC_COLLATE=C

# Session type
export XDG_CURRENT_DESKTOP=Hyprland
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=Hyprland
export XDG_RUNTIME_DIR=/run/user/$(id -u)

# D-Bus session bus — Artix/OpenRC user services put the socket here but don't
# set the env var. Without this, libsecret (Brave, Azure Storage Explorer, etc.)
# cannot find gnome-keyring and reports "no secret store".
export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"

# Cursor
export XCURSOR_SIZE=24
export XCURSOR_THEME=Adwaita
export HYPRCURSOR_SIZE=24

# NVIDIA hybrid — Intel is the compositor GPU (listed first), NVIDIA is included
# so external monitors (all ports are wired through NVIDIA on this machine) work.
# NVIDIA power-down when idle is handled by:
#   - NVreg_DynamicPowerManagement=0x02 in /etc/modprobe.d/nvidia.conf
#   - udev rule /etc/udev/rules.d/80-nvidia-pm.rules setting power/control=auto
#     on ALL NVIDIA PCI functions (GPU + audio); any function held "on" prevents D3
# With no external monitor and no app using NVIDIA, it should reach D3/suspended.
# GPU env auto-detected from which cards are actually present, so this script works
# unchanged in BOTH BIOS modes:
#   - Hybrid (Intel + NVIDIA): Intel composites (listed first), NVIDIA for external scanout.
#   - Discrete-only (iGPU disabled in BIOS): NVIDIA is the SOLE GPU and drives the internal
#     panel too (X1 Extreme Gen 5 MUX) — single GPU, no cross-GPU blits.
# by-path symlinks are stable across card-number reshuffles; an absent card -> empty string.
INTEL_CARD=$(readlink -f /dev/dri/by-path/pci-0000:00:02.0-card 2>/dev/null)
NVIDIA_CARD=$(readlink -f /dev/dri/by-path/pci-0000:01:00.0-card 2>/dev/null)

if [ -n "$INTEL_CARD" ] && [ -n "$NVIDIA_CARD" ]; then
    # Hybrid: Intel primary compositor, NVIDIA included for external monitors.
    export AQ_DRM_DEVICES="${INTEL_CARD}:${NVIDIA_CARD}"
    export LIBVA_DRIVER_NAME=iHD          # Intel iHD VA-API on hybrid
    export NVD_BACKEND=direct
    export AQ_FORCE_LINEAR_BLIT=0         # softens the hybrid cross-GPU blit
    # GBM_BACKEND=nvidia-drm / __GLX_VENDOR_LIBRARY_NAME=nvidia deliberately OMITTED here —
    # forcing NVIDIA on hybrid breaks Firefox/screensharing.
elif [ -n "$NVIDIA_CARD" ]; then
    # Discrete-only: NVIDIA is the only GPU. Force the NVIDIA stack (safe — no Intel to conflict).
    export AQ_DRM_DEVICES="${NVIDIA_CARD}"
    export GBM_BACKEND=nvidia-drm
    export __GLX_VENDOR_LIBRARY_NAME=nvidia
    export LIBVA_DRIVER_NAME=nvidia
    export NVD_BACKEND=direct
elif [ -n "$INTEL_CARD" ]; then
    # Intel-only (no dGPU present): just Intel.
    export AQ_DRM_DEVICES="${INTEL_CARD}"
    export LIBVA_DRIVER_NAME=iHD
fi

# XCompose
export XCOMPOSEFILE=~/.XCompose

# gnome-keyring: secrets and PKCS#11 only. The "ssh" component was deprecated
# upstream and silently dropped — the daemon still accepts `--components=...,ssh`
# for backward compatibility but no longer exports SSH_AUTH_SOCK, silently
# leaving SSH agent forwarding broken. Ask only for the components that work.
eval $(gnome-keyring-daemon --start --components=secrets,pkcs11)
export GNOME_KEYRING_CONTROL

# ssh-agent: dedicated agent at a predictable socket path. Idempotent —
# reuses a live agent on the expected socket, cleans up stale sockets before
# starting a fresh agent. Keys are added manually via `ssh-add` after login.
export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR}/ssh-agent.sock"
if ! SSH_AUTH_SOCK="$SSH_AUTH_SOCK" ssh-add -l >/dev/null 2>&1; then
    rm -f "$SSH_AUTH_SOCK"
    ssh-agent -a "$SSH_AUTH_SOCK" >/dev/null
fi

# Reap stale xdg-desktop-portal processes left over from a previous session
# (especially a previous IceWM session that didn't have portals). A leftover
# frontend squats the org.freedesktop.portal.Desktop D-Bus name unresponsively
# and hangs flameshot's Screenshot portal request. Match by EXECUTABLE, NOT
# cmdline — a `pkill -f xdg-desktop-portal` would also kill this very shell
# (the cmdline-match hazard). The Hyprland config's exec-once block will spawn
# fresh portal processes after this. Mirrors what start-icewm-laptop does.
for _pid in $(pgrep -f xdg-desktop-portal 2>/dev/null); do
    case "$(readlink -f /proc/$_pid/exe 2>/dev/null)" in
        */xdg-desktop-portal|*/xdg-desktop-portal-*) kill "$_pid" 2>/dev/null ;;
    esac
done

# Flameshot config toggle: under Wayland, flameshot must NOT use the
# useX11LegacyScreenshot path (it breaks capture); instead it uses the
# xdg-desktop-portal Screenshot backend (xdg-desktop-portal-hyprland). Copy
# (not symlink — Qt QSettings atomic-writes clobber symlinks) the wayland
# variant of the config onto flameshot.ini before the WM autostarts flameshot.
# The matching x11 variant carries useX11LegacyScreenshot=true and is cp'd by
# start-icewm-laptop.
# On the laptop, ~/.config/flameshot/flameshot-wayland.ini is a symlink into
# dotfiles' flameshot-laptop-wayland.ini; on the desktop it's the file
# directly. Both machines see the stable name here.
cp -f "$HOME/.config/flameshot/flameshot-wayland.ini" "$HOME/.config/flameshot/flameshot.ini" 2>/dev/null || true

exec /usr/bin/start-hyprland
